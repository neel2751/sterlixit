# ==========================================
# Sterlixit: HubSpot + Mailchimp + Chatwoot
# Copy this file to `.env.local` and fill values.
# ==========================================

# Core website
CONTACT_EMAIL=hello@sterlixit.com

# SMTP for /api/contact
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@yourdomain.com

# Tracking scripts (optional)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=123456789012345

# Live chat: Chatwoot
NEXT_PUBLIC_LIVE_CHAT_PROVIDER=chatwoot
NEXT_PUBLIC_CHATWOOT_BASE_URL=https://app.chatwoot.com
NEXT_PUBLIC_CHATWOOT_WEBSITE_TOKEN=your-chatwoot-website-token

# Optional fallback/direct chat URL (used by button if set)
NEXT_PUBLIC_LIVE_CHAT_URL=

# Keep these empty when using Chatwoot provider
NEXT_PUBLIC_LIVE_CHAT_SCRIPT_URL=
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=

# CRM + Newsletter providers
CRM_PROVIDER=hubspot
NEWSLETTER_PROVIDER=mailchimp

# Webhook fallbacks (optional)
# If set, app also forwards payloads here.
CRM_WEBHOOK_URL=
LEAD_WEBHOOK_URL=
NEWSLETTER_WEBHOOK_URL=

# HubSpot CRM mapping
HUBSPOT_PORTAL_ID=your-hubspot-portal-id
HUBSPOT_FORM_ID=your-hubspot-form-id

# Mailchimp newsletter mapping
MAILCHIMP_API_KEY=your-mailchimp-api-key-usX
MAILCHIMP_AUDIENCE_ID=your-mailchimp-audience-id

# Embeds
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/sterlixit/free-strategy-call
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps?q=595a%20Cranbrook%20Road%2C%20Gants%20Hill%2C%20London%2C%20IG2%206JZ%2C%20United%20Kingdom&output=embed
